        <oboInOwl:hasExactSynonym>花 (Japanese, exact)</oboInOwl:hasExactSynonym>
        <oboInOwl:hasNarrowSynonym>Asteraceae floret (narrow)</oboInOwl:hasNarrowSynonym>
        <oboInOwl:hasNarrowSynonym>basal flower (narrow)</oboInOwl:hasNarrowSynonym>
        <oboInOwl:hasNarrowSynonym>double flower (narrow)</oboInOwl:hasNarrowSynonym>
