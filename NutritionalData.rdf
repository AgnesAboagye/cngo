    <!-- http://purl.obolibrary.org/obo/PO_0009010 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PO_0009010">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/AGRO_00000032"/>
